generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum AttemptStatus {
  in_progress
  completed
  abandoned
}

enum GuideMessageRole {
  user
  assistant
  system
}

model User {
  id                String              @id @default(cuid())
  name              String
  email             String              @unique
  passwordHash      String
  role              UserRole            @default(user)
  gradeOrAge        String?
  preferredLanguage String              @default("ru")
  isActive          Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  attempts          TestAttempt[]
  results           TestResult[]
  savedProfessions  SavedProfession[]
  conversations     GuideConversation[]
  auditLogs         AdminAuditLog[]     @relation("AdminAuditLogs")
  targetedAuditLogs AdminAuditLog[]     @relation("TargetUserAuditLogs")

  @@index([role])
  @@index([isActive])
  @@index([createdAt])
}

model Profession {
  id                String             @id @default(cuid())
  slug              String             @unique
  titleRu           String
  titleEn           String
  descriptionRu     String
  descriptionEn     String
  category          String
  skills            String[]
  fitTags           String[]
  details           Json
  scoringTags       String[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  savedBy           SavedProfession[]
  recommendations   ResultRecommendation[]

  @@index([category])
}

model TestQuestion {
  id          String               @id @default(cuid())
  category    String
  sortOrder   Int                  @map("sort_order")
  textRu      String
  textEn      String
  type        String               @default("single_choice")
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  options     TestQuestionOption[]
  answers     TestAnswer[]

  @@unique([sortOrder])
  @@index([category])
}

model TestQuestionOption {
  id             String       @id @default(cuid())
  questionId     String
  labelRu        String
  labelEn        String
  value          Int
  scoringPayload Json
  sortOrder      Int          @map("sort_order")
  question       TestQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers        TestAnswer[]

  @@unique([questionId, sortOrder])
}

model TestAttempt {
  id          String        @id @default(cuid())
  userId      String
  startedAt   DateTime      @default(now())
  completedAt DateTime?
  status      AttemptStatus @default(in_progress)
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  answers     TestAnswer[]
  result      TestResult?

  @@index([userId, status])
}

model TestAnswer {
  id               String             @id @default(cuid())
  attemptId        String
  questionId       String
  selectedOptionId String
  numericValue     Int?
  payloadSnapshot  Json?
  attempt          TestAttempt        @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question         TestQuestion       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedOption   TestQuestionOption @relation(fields: [selectedOptionId], references: [id], onDelete: Restrict)

  @@unique([attemptId, questionId])
}

model TestResult {
  id                    String                 @id @default(cuid())
  attemptId             String                 @unique
  userId                String
  summaryRu             String
  summaryEn             String
  strengths             Json
  workStyle             Json
  preferredEnvironment  Json
  recommendedDirections Json
  roadmap               Json
  aiExplanationRu       String?
  aiExplanationEn       String?
  createdAt             DateTime               @default(now())
  attempt               TestAttempt            @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  recommendations       ResultRecommendation[]

  @@index([userId, createdAt])
}

model ResultRecommendation {
  id           String     @id @default(cuid())
  resultId     String
  professionId String
  matchPercent Int
  reasonRu     String
  reasonEn     String
  result       TestResult @relation(fields: [resultId], references: [id], onDelete: Cascade)
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)

  @@unique([resultId, professionId])
}

model SavedProfession {
  id           String     @id @default(cuid())
  userId       String
  professionId String
  createdAt    DateTime   @default(now())
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  profession   Profession @relation(fields: [professionId], references: [id], onDelete: Cascade)

  @@unique([userId, professionId])
}

model GuideConversation {
  id        String         @id @default(cuid())
  userId    String
  title     String
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  GuideMessage[]

  @@index([userId, updatedAt])
}

model GuideMessage {
  id             String           @id @default(cuid())
  conversationId String
  role           GuideMessageRole
  content        String
  createdAt      DateTime         @default(now())
  conversation   GuideConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminUserId String
  action      String
  targetUserId String?
  metadata    Json?
  createdAt   DateTime @default(now())
  adminUser   User     @relation("AdminAuditLogs", fields: [adminUserId], references: [id], onDelete: Cascade)
  targetUser  User?    @relation("TargetUserAuditLogs", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId, createdAt])
  @@index([targetUserId])
}
